# Copy this file to `.env` in the same directory as `docker-compose.yml`, then edit values.
# Docker Compose loads `.env` automatically for variable substitution (see compose `environment:`).

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Shared secret: Bearer token for `/v1/*` on the API port (3901 by default) and
# the management UI login on port 80. Must match Admin → Storage → Remote API secret.
# Generate a long random value before production, e.g. `openssl rand -hex 32`
STORAGE_API_SECRET=change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Optional (defaults are applied by the app unless you wire them through Compose)
# -----------------------------------------------------------------------------

# Initial storage mode when no persisted file exists yet:
#   active       — normal reads and writes
#   maintenance  — GET/HEAD only; POST/PUT/DELETE return 503
#   disabled     — all `/v1/*` return 503 (health fails; use only when draining)
# After the first save from the UI, `DATA_ROOT/.file-uploader-node/node_state.json` wins.
# STORAGE_NODE_STATUS=active

# Max objects the UI “Node transfer” wizard will walk (safety cap).
# MAX_TRANSFER_OBJECTS=200000

# Max bytes accepted for a single PUT body (default 64 GiB). Example for 8 GiB: 8589934592
# MAX_PUT_BYTES=68719476736

# Listen ports and data directory are normally set in `docker-compose.yml` (`UI_PORT`,
# `API_PORT`, `DATA_ROOT`). Override here only if your Compose file passes them through.
# UI_PORT=80
# API_PORT=3901
# DATA_ROOT=/data

# Legacy: if set and `API_PORT` is unset, `PORT` is used as the API listen port only.
# PORT=3901
